        "        'reasoning': reasoning,\n",
        "        'decision_time': elapsed\n",
        "    })\n",
        "\n",
        "# Calculate metrics\n",
        "strict_accuracy = sum(r['strict_correct'] for r in results) / len(results) * 100\n",
